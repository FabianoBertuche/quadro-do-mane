{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@quadro/database": ["packages/database/src"],
      "@quadro/utils": ["packages/utils/src"],
      "@quadro/ui": ["packages/ui/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
