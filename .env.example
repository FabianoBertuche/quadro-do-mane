# Quadro do Mané — variáveis de ambiente
#
# IMPORTANTE: gere segredos fortes antes de subir a API em qualquer ambiente.
#   openssl rand -hex 64  -> 128 chars (use como JWT_SECRET e JWT_REFRESH_SECRET)
#   openssl rand -hex 32  -> 64 chars  (use como ENCRYPTION_KEY)
# A API falha rápido (boot aborta) se qualquer variável obrigatória estiver ausente.

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quadro_do_mane?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────
# Segredos hex de pelo menos 32 bytes (64 chars hex). OBRIGATÓRIOS.
JWT_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Encryption (AES-256-GCM) ─────────────────────────────────────────────
# Chave de 32 bytes hex (64 chars). Usada para criptografar senhas de e-mail.
ENCRYPTION_KEY="CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32"

# ─── API ─────────────────────────────────────────────────────────────────
API_PORT=3001
API_PREFIX=/api

# ─── Frontend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── Redis removido ─────────────────────────────────────────────────────
# A denylist de tokens JWT usa a tabela `token_denylist` no PostgreSQL
# (cleanup via pg_cron, ver DATABASE.md).

# ─── S3 / Object Storage ─────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=quadro-do-mane

# ─── Cookie / CORS ───────────────────────────────────────────────────────
# Em produção: COOKIE_DOMAIN=seudominio.com e COOKIE_SECURE=true
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
# Origens permitidas pelo CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000

# ─── Security ────────────────────────────────────────────────────────────
# Rounds do bcrypt (mínimo 8, recomendado 12+)
BCRYPT_ROUNDS=12

# ─── Seed ────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@quadrodomane.local
SEED_ADMIN_PASSWORD="AlterarNoPrimeiroLogin123!"
