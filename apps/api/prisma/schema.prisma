generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String         @map("password_hash")
  avatarUrl     String?        @map("avatar_url")
  phone         String?
  isActive      Boolean        @default(true) @map("is_active")
  lastLoginAt   DateTime?      @map("last_login_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  auditLogs     AuditLog[]
  tenantUsers   TenantUser[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Plan {
  id            String         @id @default(uuid())
  name          String
  description   String?
  maxUsers      Int?           @map("max_users")
  maxProjects   Int?           @map("max_projects")
  maxStorageMb  Int?           @map("max_storage_mb")
  monthlyPrice  Decimal        @default(0) @map("monthly_price") @db.Decimal(10, 2)
  annualPrice   Decimal        @default(0) @map("annual_price") @db.Decimal(10, 2)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  subscriptions Subscription[]

  @@map("plans")
}

model Tenant {
  id                  String               @id @default(uuid())
  name                String
  slug                String               @unique
  legalName           String?              @map("legal_name")
  documentNumber      String?              @map("document_number")
  email               String?
  phone               String?
  status              TenantStatus         @default(ACTIVE)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  activityLogs        ActivityLog[]
  attachments         Attachment[]
  auditLogs           AuditLog[]
  automations         Automation[]
  contacts            Contact[]
  customFieldValues   CustomFieldValue[]
  customFields        CustomField[]
  eventAttendees      EventAttendee[]
  events              Event[]
  notifications       Notification[]
  projectMembers      ProjectMember[]
  projectViews        ProjectView[]
  projects            Project[]
  roles               Role[]
  subscriptions       Subscription[]
  taskAssignees       TaskAssignee[]
  taskChecklistItems  TaskChecklistItem[]
  taskChecklists      TaskChecklist[]
  taskComments        TaskComment[]
  taskPriorities      TaskPriority[]
  taskStatuses        TaskStatus[]
  taskTagLinks        TaskTagLink[]
  taskTags            TaskTag[]
  tasks               Task[]
  teamMembers         TeamMember[]
  teams               Team[]
  tenantUsers         TenantUser[]
  usageCounters       UsageCounter[]
  emailSettings       EmailSetting[]
  emailTenantSettings EmailTenantSetting[]
  refreshTokens       RefreshToken[]

  @@map("tenants")
}

model TenantUser {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  userId              String              @map("user_id")
  roleId              String?             @map("role_id")
  jobTitle            String?             @map("job_title")
  department          String?
  isActive            Boolean             @default(true) @map("is_active")
  status              TenantUserStatus    @default(ACTIVE)
  mustChangePassword  Boolean             @default(false) @map("must_change_password")
  lastInviteAt        DateTime?           @map("last_invite_at")
  disabledAt          DateTime?           @map("disabled_at")
  disabledReason      String?             @map("disabled_reason")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  activityLogs        ActivityLog[]
  uploadedAttachments Attachment[]
  automations         Automation[]
  eventAttendances    EventAttendee[]
  createdEvents       Event[]
  notifications       Notification[]
  projectMemberships  ProjectMember[]
  ownedProjects       Project[]           @relation("ProjectOwner")
  taskAssignees       TaskAssignee[]
  checklistItemsDone  TaskChecklistItem[] @relation("ChecklistDoneBy")
  taskComments        TaskComment[]
  assignedTasks       Task[]              @relation("TaskAssignee")
  reportedTasks       Task[]              @relation("TaskReporter")
  teamMemberships     TeamMember[]
  managedTeams        Team[]              @relation("TeamManager")
  role                Role?               @relation(fields: [roleId], references: [id])
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailSettings              EmailSetting[]
  emailTenantSettingsUpdated EmailTenantSetting[] @relation("EmailTenantSettingUpdater")

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

model EmailSetting {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  tenantUserId       String   @map("tenant_user_id")
  protocol           String   @default("imap") // imap, smtp
  // AES-256-GCM fields - IV aleatorio por registro, authTag para integridade
  passwordCiphertext String   @map("password_ciphertext")
  passwordIv         String   @map("password_iv")
  passwordAuthTag    String   @map("password_auth_tag")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenantUser TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantUserId, protocol])
  @@map("email_settings")
}

/// Configuração de servidor IMAP/SMTP do tenant. Definida UMA vez pelo admin.
/// O usuário final (colaborador) só cadastra a senha em EmailSetting.
model EmailTenantSetting {
  id                    String   @id @default(uuid())
  tenantId              String   @map("tenant_id")
  emailDomain           String   @map("email_domain")
  detectionMode         String   @default("PRESET") @map("detection_mode") // PRESET | CUSTOM
  presetKey             String?  @map("preset_key")
  imapHost              String   @map("imap_host")
  imapPort              Int      @map("imap_port")
  imapSecure            Boolean  @default(true) @map("imap_secure")
  smtpHost              String   @map("smtp_host")
  smtpPort              Int      @map("smtp_port")
  smtpSecure            Boolean  @default(true) @map("smtp_secure")
  updatedByTenantUserId String?  @map("updated_by_tenant_user_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedBy TenantUser? @relation("EmailTenantSettingUpdater", fields: [updatedByTenantUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId])
  @@index([emailDomain])
  @@map("email_tenant_settings")
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String?          @map("tenant_id")
  name            String
  description     String?
  isSystemRole    Boolean          @default(false) @map("is_system_role")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUsers     TenantUser[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  description     String?
  module          String
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Team {
  id                  String       @id @default(uuid())
  tenantId            String       @map("tenant_id")
  name                String
  description         String?
  managerTenantUserId String?      @map("manager_tenant_user_id")
  color               String?
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  projects            Project[]
  tasks               Task[]
  members             TeamMember[]
  manager             TenantUser?  @relation("TeamManager", fields: [managerTenantUserId], references: [id])
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("teams")
}

model TeamMember {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  teamId       String     @map("team_id")
  tenantUserId String     @map("tenant_user_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUser   TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@unique([teamId, tenantUserId])
  @@map("team_members")
}

model Project {
  id                String          @id @default(uuid())
  tenantId          String          @map("tenant_id")
  name              String
  code              String?
  description       String?
  status            ProjectStatus   @default(ACTIVE)
  priority          String?
  ownerTenantUserId String?         @map("owner_tenant_user_id")
  teamId            String?         @map("team_id")
  startDate         DateTime?       @map("start_date")
  dueDate           DateTime?       @map("due_date")
  completedAt       DateTime?       @map("completed_at")
  progressPercent   Int             @default(0) @map("progress_percent")
  color             String?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  archivedAt        DateTime?       @map("archived_at")
  attachments       Attachment[]
  events            Event[]         @relation("ProjectEvents")
  members           ProjectMember[]
  views             ProjectView[]
  owner             TenantUser?     @relation("ProjectOwner", fields: [ownerTenantUserId], references: [id])
  team              Team?           @relation(fields: [teamId], references: [id])
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks             Task[]

  @@index([tenantId, status])
  @@index([tenantId, ownerTenantUserId])
  @@map("projects")
}

model ProjectMember {
  id            String     @id @default(uuid())
  tenantId      String     @map("tenant_id")
  projectId     String     @map("project_id")
  tenantUserId  String     @map("tenant_user_id")
  roleInProject String?    @map("role_in_project")
  createdAt     DateTime   @default(now()) @map("created_at")
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUser    TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@unique([projectId, tenantUserId])
  @@map("project_members")
}

model ProjectView {
  id         String          @id @default(uuid())
  tenantId   String          @map("tenant_id")
  projectId  String          @map("project_id")
  name       String
  type       ProjectViewType
  configJson String?         @map("config_json")
  createdBy  String?         @map("created_by")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("project_views")
}

model TaskStatus {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  slug      String
  color     String?
  position  Int      @default(0)
  category  String   @default("pending")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@unique([tenantId, slug])
  @@map("task_statuses")
}

model TaskPriority {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  level     Int      @default(0)
  color     String?
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Task      Task[]

  @@map("task_priorities")
}

model Task {
  id                   String          @id @default(uuid())
  tenantId             String          @map("tenant_id")
  projectId            String          @map("project_id")
  parentTaskId         String?         @map("parent_task_id")
  title                String
  description          String?
  statusId             String?         @map("status_id")
  priorityId           String?         @map("priority_id")
  assigneeTenantUserId String?         @map("assignee_tenant_user_id")
  reporterTenantUserId String?         @map("reporter_tenant_user_id")
  teamId               String?         @map("team_id")
  startDate            DateTime?       @map("start_date")
  dueDate              DateTime?       @map("due_date")
  completedAt          DateTime?       @map("completed_at")
  estimatedMinutes     Int?            @map("estimated_minutes")
  spentMinutes         Int             @default(0) @map("spent_minutes")
  storyPoints          Int?            @map("story_points")
  kanbanPosition       Int             @default(0) @map("kanban_position")
  sortOrder            Int             @default(0) @map("sort_order")
  isBlocked            Boolean         @default(false) @map("is_blocked")
  blockedReason        String?         @map("blocked_reason")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  archivedAt           DateTime?       @map("archived_at")
  attachments          Attachment[]
  events               Event[]         @relation("TaskEvents")
  assignees            TaskAssignee[]
  checklists           TaskChecklist[]
  comments             TaskComment[]
  tagLinks             TaskTagLink[]
  assignee             TenantUser?     @relation("TaskAssignee", fields: [assigneeTenantUserId], references: [id])
  parentTask           Task?           @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks             Task[]          @relation("SubTasks")
  priority             TaskPriority?   @relation(fields: [priorityId], references: [id])
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter             TenantUser?     @relation("TaskReporter", fields: [reporterTenantUserId], references: [id])
  status               TaskStatus?     @relation(fields: [statusId], references: [id])
  team                 Team?           @relation(fields: [teamId], references: [id])
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId])
  @@index([tenantId, assigneeTenantUserId])
  @@index([tenantId, statusId])
  @@index([tenantId, dueDate])
  @@index([tenantId, archivedAt])
  @@map("tasks")
}

model TaskAssignee {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  taskId       String     @map("task_id")
  tenantUserId String     @map("tenant_user_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUser   TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@unique([taskId, tenantUserId])
  @@map("task_assignees")
}

model TaskTag {
  id        String        @id @default(uuid())
  tenantId  String        @map("tenant_id")
  name      String
  color     String?
  createdAt DateTime      @default(now()) @map("created_at")
  tagLinks  TaskTagLink[]
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("task_tags")
}

model TaskTagLink {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  taskId   String  @map("task_id")
  tagId    String  @map("tag_id")
  tag      TaskTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
  @@map("task_tag_links")
}

model TaskChecklist {
  id        String              @id @default(uuid())
  tenantId  String              @map("tenant_id")
  taskId    String              @map("task_id")
  title     String
  position  Int                 @default(0)
  createdAt DateTime            @default(now()) @map("created_at")
  items     TaskChecklistItem[]
  task      Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("task_checklists")
}

model TaskChecklistItem {
  id                 String        @id @default(uuid())
  tenantId           String        @map("tenant_id")
  checklistId        String        @map("checklist_id")
  content            String
  isDone             Boolean       @default(false) @map("is_done")
  doneByTenantUserId String?       @map("done_by_tenant_user_id")
  doneAt             DateTime?     @map("done_at")
  position           Int           @default(0)
  createdAt          DateTime      @default(now()) @map("created_at")
  checklist          TaskChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  doneBy             TenantUser?   @relation("ChecklistDoneBy", fields: [doneByTenantUserId], references: [id])
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("task_checklist_items")
}

model TaskComment {
  id                 String     @id @default(uuid())
  tenantId           String     @map("tenant_id")
  taskId             String     @map("task_id")
  authorTenantUserId String     @map("author_tenant_user_id")
  content            String
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")
  author             TenantUser @relation(fields: [authorTenantUserId], references: [id])
  task               Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model Attachment {
  id                     String     @id @default(uuid())
  tenantId               String     @map("tenant_id")
  taskId                 String?    @map("task_id")
  projectId              String?    @map("project_id")
  uploadedByTenantUserId String     @map("uploaded_by_tenant_user_id")
  fileName               String     @map("file_name")
  filePath               String     @map("file_path")
  mimeType               String?    @map("mime_type")
  fileSize               Int?       @map("file_size")
  createdAt              DateTime   @default(now()) @map("created_at")
  project                Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task                   Task?      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant                 Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy             TenantUser @relation(fields: [uploadedByTenantUserId], references: [id])

  @@map("attachments")
}

model Event {
  id                    String          @id @default(uuid())
  tenantId              String          @map("tenant_id")
  title                 String
  description           String?
  type                  String?
  startAt               DateTime        @map("start_at")
  endAt                 DateTime        @map("end_at")
  allDay                Boolean         @default(false) @map("all_day")
  createdByTenantUserId String          @map("created_by_tenant_user_id")
  relatedProjectId      String?         @map("related_project_id")
  relatedTaskId         String?         @map("related_task_id")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  attendees             EventAttendee[]
  createdBy             TenantUser      @relation(fields: [createdByTenantUserId], references: [id])
  project               Project?        @relation("ProjectEvents", fields: [relatedProjectId], references: [id])
  task                  Task?           @relation("TaskEvents", fields: [relatedTaskId], references: [id])
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("events")
}

model EventAttendee {
  id             String     @id @default(uuid())
  tenantId       String     @map("tenant_id")
  eventId        String     @map("event_id")
  tenantUserId   String     @map("tenant_user_id")
  responseStatus String?    @map("response_status")
  event          Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUser     TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, tenantUserId])
  @@map("event_attendees")
}

model Contact {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  name       String
  company    String?
  department String?
  role       String?
  email      String?
  phone      String?
  mobile     String?
  extension  String?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

model Notification {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  tenantUserId String     @map("tenant_user_id")
  type         String
  title        String
  message      String
  payloadJson  String?    @map("payload_json")
  isRead       Boolean    @default(false) @map("is_read")
  readAt       DateTime?  @map("read_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUser   TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, tenantUserId, isRead])
  @@map("notifications")
}

model ActivityLog {
  id                String      @id @default(uuid())
  tenantId          String      @map("tenant_id")
  actorTenantUserId String?     @map("actor_tenant_user_id")
  entityType        String      @map("entity_type")
  entityId          String      @map("entity_id")
  action            String
  oldValuesJson     String?     @map("old_values_json")
  newValuesJson     String?     @map("new_values_json")
  createdAt         DateTime    @default(now()) @map("created_at")
  actor             TenantUser? @relation(fields: [actorTenantUserId], references: [id])
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String?  @map("tenant_id")
  actorUserId  String?  @map("actor_user_id")
  action       String
  targetType   String?  @map("target_type")
  targetId     String?  @map("target_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  metadataJson String?  @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")
  actor        User?    @relation(fields: [actorUserId], references: [id])
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Subscription {
  id          String             @id @default(uuid())
  tenantId    String             @map("tenant_id")
  planId      String             @map("plan_id")
  status      SubscriptionStatus @default(ACTIVE)
  startedAt   DateTime           @map("started_at")
  expiresAt   DateTime?          @map("expires_at")
  trialEndsAt DateTime?          @map("trial_ends_at")
  cancelledAt DateTime?          @map("cancelled_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  plan        Plan               @relation(fields: [planId], references: [id])
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UsageCounter {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  metricCode   String    @map("metric_code")
  currentValue Int       @default(0) @map("current_value")
  periodStart  DateTime? @map("period_start")
  periodEnd    DateTime? @map("period_end")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metricCode])
  @@map("usage_counters")
}

model Automation {
  id                    String     @id @default(uuid())
  tenantId              String     @map("tenant_id")
  name                  String
  description           String?
  triggerType           String     @map("trigger_type")
  conditionsJson        String?    @map("conditions_json")
  actionsJson           String?    @map("actions_json")
  isActive              Boolean    @default(true) @map("is_active")
  createdByTenantUserId String     @map("created_by_tenant_user_id")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  createdBy             TenantUser @relation(fields: [createdByTenantUserId], references: [id])
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("automations")
}

model CustomField {
  id         String             @id @default(uuid())
  tenantId   String             @map("tenant_id")
  entityType String             @map("entity_type")
  name       String
  fieldType  String             @map("field_type")
  configJson String?            @map("config_json")
  isRequired Boolean            @default(false) @map("is_required")
  createdAt  DateTime           @default(now()) @map("created_at")
  values     CustomFieldValue[]
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("custom_fields")
}

model CustomFieldValue {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  customFieldId String      @map("custom_field_id")
  entityId      String      @map("entity_id")
  valueText     String?     @map("value_text")
  valueNumber   Decimal?    @map("value_number") @db.Decimal(18, 4)
  valueDate     DateTime?   @map("value_date")
  valueBoolean  Boolean?    @map("value_boolean")
  valueJson     String?     @map("value_json")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("custom_field_values")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TenantUserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectViewType {
  LIST
  KANBAN
  CALENDAR
  TIMELINE
  DASHBOARD
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

model RefreshToken {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  tenantId     String   @map("tenant_id")
  // SHA-256 do refresh token em texto puro - nunca armazenar o token.
  tokenHash    String   @unique @map("token_hash")
  // Família: detecta reuso de token revogado (alerta de roubo).
  family       String
  isRevoked    Boolean  @default(false) @map("is_revoked")
  replacedById String?  @map("replaced_by_id")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model LoginAttempt {
  id        String   @id @default(uuid())
  email     String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  success   Boolean
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
  @@map("login_attempts")
}

/// Denylist de access tokens JWT revogados (substitui o Redis).
/// Linhas expiram em `expiresAt` e são limpas periodicamente por pg_cron.
model TokenDenylist {
  id        String   @id @default(uuid())
  // SHA-256 do token em texto puro, prefixado com 'access:'. Único.
  tokenHash String   @unique @map("token_hash")
  userId    String?  @map("user_id")
  reason    String?  @map("reason")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@index([userId])
  @@map("token_denylist")
}
