{
  "name": "quadro-do-mane",
  "version": "1.0.0",
  "private": true,
  "description": "Quadro do Mané - SaaS Task Management Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/generate-env.js",
    "start": "node scripts/start-all.js",
    "dev": "node scripts/dev-all.js",
    "regen-keys": "node scripts/regenerate-secrets.js",
    "kill-port": "node scripts/kill-port.js",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:all": "npm run build:api && npm run build:web",
    "start:api": "npm run start:prod --workspace=apps/api",
    "start:web": "npm run start --workspace=apps/web",
    "db:migrate": "npm run migrate --workspace=apps/api",
    "db:seed": "npm run seed --workspace=apps/api",
    "db:generate": "npm run generate --workspace=apps/api"
  },
  "dependencies": {
    "dompurify": "^3.4.11"
  }
}
